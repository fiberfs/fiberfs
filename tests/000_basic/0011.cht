chttp_test "TCP pool tests 2"

config_add TCP_POOL_SIZE 5
config_add TCP_POOL_AGE_MSEC 700

dns_lookup_or_skip dns02.nulltech.systems

chttp_init

chttp_connect dns02.nulltech.systems 2
tcp_pool_fake_connect
chttp_reset

chttp_connect dns02.nulltech.systems 2
tcp_pool_fake_connect
chttp_reset

chttp_connect dns02.nulltech.systems 2
tcp_pool_fake_connect
chttp_reset

chttp_connect dns02.nulltech.systems 2
tcp_pool_fake_connect
chttp_reset

chttp_connect dns02.nulltech.systems 2
tcp_pool_fake_connect
chttp_reset

chttp_connect dns02.nulltech.systems 2
tcp_pool_fake_connect
chttp_reset

chttp_connect dns02.nulltech.systems 2
tcp_pool_fake_connect
chttp_reset

chttp_connect dns02.nulltech.systems 2
tcp_pool_fake_connect
chttp_reset

chttp_connect dns02.nulltech.systems 2
tcp_pool_fake_connect
chttp_reset

chttp_connect dns02.nulltech.systems 2
tcp_pool_fake_connect
chttp_reset

# We added 10 connections to the pool, 5 were nuked (LRU) out
#tcp_pool_debug

sleep_ms 720

chttp_connect dns02.nulltech.systems 2
tcp_pool_fake_connect
chttp_reset

chttp_connect dns02.nulltech.systems 2
tcp_pool_fake_connect
chttp_reset

# Added 2 more connections (12 total), the previous 5 got removed (1 nuke, 4 expired)
tcp_pool_debug

chttp_url /
chttp_connect dns02.nulltech.systems 2
chttp_send_only
chttp_take_error
chttp_reset

chttp_url /
chttp_connect dns02.nulltech.systems 2
chttp_send_only
chttp_take_error
chttp_reset

chttp_url /
chttp_connect dns02.nulltech.systems 2
chttp_send_only
chttp_take_error
chttp_reset

chttp_url /
chttp_connect dns02.nulltech.systems 2
chttp_send_only
chttp_take_error
chttp_reset

# The 2 remaining connections were taken (hit), 2 misses
tcp_pool_debug

equal $tcp_pool_lookups 4
equal $tcp_pool_cache_hits 2
equal $tcp_pool_cache_misses 2
equal $tcp_pool_insertions 12
equal $tcp_pool_expired 4
equal $tcp_pool_deleted 12
equal $tcp_pool_nuked 6
